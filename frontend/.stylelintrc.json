{
  "customSyntax": "postcss-scss",
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "components",
          "utilities",
          "responsive",
          "variants",
          "config"
        ]
      }
    ]
  }
}
